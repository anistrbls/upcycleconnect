SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@upcycleconnect.fr
SMTP_FROM_NAME=UpcycleConnect
SMTP_REPLY_TO=
SMTP_TLS=false
SMTP_STARTTLS=true
SMTP_SKIP_VERIFY=false
SMTP_TIMEOUT_SECONDS=15

# Registre Docker (prod images)
